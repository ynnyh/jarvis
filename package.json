{
  "name": "jarvis-desktop",
  "version": "0.10.5",
  "description": "Jarvis 桌面任务助手（Tauri + Vue）",
  "type": "module",
  "scripts": {
    "check:text": "node scripts/check-mojibake.mjs --mode=strict",
    "check:text:full": "node scripts/check-mojibake.mjs --mode=full",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "desktop:dev": "node scripts/dev.mjs",
    "desktop:build": "tauri build",
    "desktop:build-macos-dev": "tauri build --target universal-apple-darwin",
    "desktop:build-binary": "tauri build --no-bundle",
    "release:gitee": "node scripts/publish-to-gitee.mjs",
    "release:sync-gitee": "node scripts/publish-to-gitee.mjs --sync-from-github",
    "pre-release": "node scripts/pre-release.mjs",
    "desktop:portable": "npm run desktop:build-binary && node scripts/portable-zip.mjs",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "ai",
    "zentao",
    "task",
    "agent"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2.5.0",
    "@types/node": "^25.7.0",
    "eslint": "^10.5.0",
    "eslint-plugin-vue": "^10.9.2",
    "globals": "^17.6.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.1",
    "undici": "^7.25.0",
    "vitepress": "^1.6.4",
    "vue-eslint-parser": "^10.4.1"
  },
  "dependencies": {
    "@tailwindcss/postcss": "^4.3.0",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-autostart": "^2.5.1",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-process": "^2.3.0",
    "@tauri-apps/plugin-updater": "^2.5.0",
    "@vitejs/plugin-vue": "^6.0.6",
    "autoprefixer": "^10.5.0",
    "croner": "^10.0.1",
    "highlight.js": "^11.11.1",
    "lottie-web": "^5.13.0",
    "marked": "^18.0.4",
    "pinia": "^3.0.4",
    "postcss": "^8.5.14",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.16",
    "vue": "^3.5.34"
  }
}
