# 依赖与构建产物
node_modules/
dist/
build/
build-out/
*.tsbuildinfo

# Rust / Tauri
src-tauri/target/
src-tauri/build-out/
src-tauri/gen/schemas/
# 打包资源（node.exe ~66MB + daemon.mjs 由 desktop:prebuild 生成，不入库）
# 但 zentao-test.mjs 是手写源码，必须入库 —— 用 ! 反向排除
src-tauri/bundled/*
!src-tauri/bundled/zentao-test.mjs

# 凭据 / 用户私有配置（含禅道账号密码、工蜂 token）
.env
.env.local
.env.*.local
.jarvis/

# Tauri 签名密钥（绝对不能进库；PowerShell 不展开 ~ 会在项目根建出 ~ 目录，要拦死）
~/
.tauri/
.tauri-ci/
*.key
*.key.pub

# 编辑器 / IDE
.trae/
.vscode/
.idea/
*.swp

# 临时 / 调试数据文件（爬取的页面、API 快照等）
data/

# 临时 / 调试输出
result-tmp.json
r.json
*.log

# 二进制
rustup-init.exe

# OS
.DS_Store
Thumbs.db
desktop.ini
