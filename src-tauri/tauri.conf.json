{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Jarvis",
  "version": "0.2.4",
  "identifier": "com.jarvis.desktop",
  "build": {
    "frontendDist": "../dist/ui",
    "beforeBuildCommand": "tsc && npx vite build --config vite.config.ts",
    "beforeDevCommand": "tsc && npx vite --config vite.config.ts",
    "devUrl": "http://localhost:5174"
  },
  "app": {
    "windows": [
      {
        "label": "avatar",
        "title": "Jarvis",
        "width": 300,
        "height": 400,
        "center": false,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "fullscreen": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "focus": true,
        "visible": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "resources": {
      "bundled/daemon.mjs": "bundled/daemon.mjs",
      "bundled/node.exe": "bundled/node.exe",
      "bundled/zentao-test.mjs": "bundled/zentao-test.mjs"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
