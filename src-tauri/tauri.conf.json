{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Jarvis",
  "version": "0.6.4",
  "identifier": "com.jarvis.desktop",
  "build": {
    "frontendDist": "../dist/ui",
    "beforeBuildCommand": "npx vite build --config vite.config.ts",
    "beforeDevCommand": "npx vite --config vite.config.ts",
    "devUrl": "http://localhost:5174"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "avatar",
        "title": "Jarvis",
        "width": 400,
        "height": 560,
        "center": false,
        "resizable": false,
        "maximizable": false,
        "minimizable": false,
        "closable": false,
        "fullscreen": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "decorations": false,
        "shadow": false,
        "focus": true,
        "visible": true
      },
      {
        "label": "chat",
        "title": "Chat",
        "url": "chat.html",
        "width": 900,
        "height": 650,
        "minWidth": 600,
        "minHeight": 420,
        "center": true,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "fullscreen": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "transparent": false,
        "decorations": false,
        "shadow": true,
        "focus": true,
        "visible": false
      },
      {
        "label": "settings",
        "title": "Settings",
        "url": "settings.html",
        "width": 900,
        "height": 650,
        "minWidth": 600,
        "minHeight": 420,
        "center": true,
        "resizable": true,
        "maximizable": true,
        "minimizable": true,
        "closable": true,
        "fullscreen": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "transparent": false,
        "decorations": false,
        "shadow": true,
        "focus": true,
        "visible": false
      },
      {
        "label": "writeHours",
        "title": "写入工时到禅道",
        "url": "writeHours.html",
        "width": 520,
        "height": 640,
        "minWidth": 420,
        "minHeight": 520,
        "center": true,
        "resizable": true,
        "maximizable": false,
        "minimizable": true,
        "closable": true,
        "fullscreen": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "transparent": false,
        "decorations": false,
        "shadow": true,
        "focus": true,
        "visible": false
      },
      {
        "label": "manualHours",
        "title": "手动写工时到禅道",
