        "width": 520,
        "height": 640,
        "minWidth": 420,
        "minHeight": 520,
        "center": true,
        "resizable": true,
        "maximizable": false,
        "minimizable": true,
        "closable": true,
        "fullscreen": false,
        "alwaysOnTop": true,
        "skipTaskbar": false,
        "transparent": false,
        "decorations": false,
        "shadow": true,
        "focus": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "app", "dmg"],
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
